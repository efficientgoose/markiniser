{
  "name": "markiniser",
  "version": "0.1.2",
  "description": "Local-first markdown organizer for browsing, searching, and editing markdown files on localhost.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/efficientgoose/markiniser.git"
  },
  "homepage": "https://github.com/efficientgoose/markiniser#readme",
  "bugs": {
    "url": "https://github.com/efficientgoose/markiniser/issues"
  },
  "bin": {
    "markiniser": "./bin/markiniser.js"
  },
  "files": [
    "bin/",
    "packages/core/dist/*.js",
    "packages/server/dist/*.js",
    "packages/web/dist/**",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "package:github": "npm run build && node scripts/github-package.mjs",
    "publish:github": "npm run package:github && npm publish ./.pkg/github --registry=https://npm.pkg.github.com",
    "pack:github": "npm run package:github && npm pack --dry-run ./.pkg/github",
    "prepack": "npm run build",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.2.0",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.39",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.1",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.3.2",
    "flexsearch": "^0.8.212",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
